{
  "name": "venfork",
  "version": "0.6.0",
  "description": "Create and manage private mirrors for vendor development",
  "type": "module",
  "bin": {
    "venfork": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "compile": "bun build ./src/index.ts --compile --outfile ./dist/venfork",
    "dev": "bun run ./src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:e2e": "VENFORK_E2E=1 bun test tests/e2e --timeout 900000",
    "test:e2e:dispatch": "VENFORK_E2E=1 VENFORK_E2E_REAL_DISPATCH=1 bun test tests/e2e --timeout 900000",
    "test:e2e:cron": "VENFORK_E2E=1 VENFORK_E2E_REAL_CRON=1 bun test tests/e2e --timeout 1800000",
    "setup": "bun install && bun run build",
    "link": "bun link",
    "unlink": "bun unlink",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "check": "biome check --write ."
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cli",
    "git",
    "github",
    "mirror",
    "fork",
    "vendor",
    "contractor"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cabljac/venfork.git"
  },
  "bugs": {
    "url": "https://github.com/cabljac/venfork/issues"
  },
  "homepage": "https://github.com/cabljac/venfork#readme",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "execa": "^9.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/bun": "latest",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
